# ============================================================
# Banco de dados (PostgreSQL — obrigatório)
# ============================================================
# O schema usa recursos exclusivos do Postgres (campos JSON, busca
# case-insensitive, Decimal), então SQLite NÃO é suportado.
#
# Opção A — Postgres local via Docker (recomendado): npm run db:up
DATABASE_URL="postgresql://imp:imp@localhost:5432/imp?schema=public"
#
# Opção B — Postgres hospedado gratuito (zero instalação): crie um banco no
# Neon (neon.tech) ou Supabase e cole a connection string aqui. Continua
# sendo "local" no sentido de desenvolvimento, sem precisar de Docker.

# ============================================================
# API
# ============================================================
API_PORT=3333
NODE_ENV=development

# ============================================================
# IA (sugestão de descrições) — Claude API
# Crie sua chave em https://platform.claude.com
# ============================================================
ANTHROPIC_API_KEY=

# ============================================================
# Autenticação (login do painel e do app Android)
# ============================================================
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ============================================================
# Credenciais dos marketplaces (preencher quando integrar)
# ============================================================
# Mercado Livre — https://developers.mercadolivre.com.br
ML_CLIENT_ID=
ML_CLIENT_SECRET=
ML_REDIRECT_URI=http://localhost:3333/marketplaces/mercado-livre/callback

# Shopee — https://open.shopee.com
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_REDIRECT_URI=https://integracao-api-six.vercel.app/api/marketplaces/shopee/callback

# Americanas (Skyhub) — credenciais vão na CONTA (painel > Marketplaces),
# campos: user_email, api_key, account_manager_key

# Cron de importação automática (Vercel)
CRON_SECRET=

# Amazon SP-API — https://developer-docs.amazon.com/sp-api
AMAZON_LWA_CLIENT_ID=
AMAZON_LWA_CLIENT_SECRET=
AMAZON_REFRESH_TOKEN=

# Magalu / B2W (Americanas)
MAGALU_CLIENT_ID=
MAGALU_CLIENT_SECRET=
