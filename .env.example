# ============================================================
# Banco de dados
# ============================================================
# Padrão: Postgres via docker-compose (npm run db:up)
DATABASE_URL="postgresql://imp:imp@localhost:5432/imp?schema=public"

# Fallback SEM Docker (SQLite) — para usar, troque o provider em
# apps/api/prisma/schema.prisma de "postgresql" para "sqlite" e use:
# DATABASE_URL="file:./dev.db"

# ============================================================
# API
# ============================================================
API_PORT=3333
NODE_ENV=development

# ============================================================
# Credenciais dos marketplaces (preencher quando integrar)
# ============================================================
# Mercado Livre — https://developers.mercadolivre.com.br
ML_CLIENT_ID=
ML_CLIENT_SECRET=
ML_REDIRECT_URI=http://localhost:3333/marketplaces/mercado-livre/callback

# Shopee — https://open.shopee.com
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=

# Amazon SP-API — https://developer-docs.amazon.com/sp-api
AMAZON_LWA_CLIENT_ID=
AMAZON_LWA_CLIENT_SECRET=
AMAZON_REFRESH_TOKEN=

# Magalu / B2W (Americanas)
MAGALU_CLIENT_ID=
MAGALU_CLIENT_SECRET=
