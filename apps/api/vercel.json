{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": { "includeFiles": ["prisma/**"] }
    }
  ],
  "routes": [{ "src": "/(.*)", "dest": "api/index.ts" }],
  "crons": [
    {
      "path": "/api/cron/import-orders",
      "schedule": "0 9 * * *"
    }
  ]
}
